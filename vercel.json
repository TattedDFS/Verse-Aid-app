{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/privacy-policy.html", "dest": "/privacy-policy.html" },
    { "src": "/terms-of-service.html", "dest": "/terms-of-service.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
